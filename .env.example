# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_ORCHESTRATOR_URL: Base URL of the platform orchestrator BFF, used by the
# create wizard to validate J3 tunable knobs (POST /api/v1/deployments:validate).
# Empty/unset => same-origin: the Vite dev proxy forwards /api to the target below.
VITE_ORCHESTRATOR_URL="http://localhost:8080"

# Microsoft Entra SPA sign-in (Phase F). Empty => mock mode (no real auth).
VITE_ENTRA_CLIENT_ID=""
VITE_ENTRA_AUTHORITY="https://login.microsoftonline.com/8f77fb2e-7e77-477e-9a03-d078b7aad9c3"
VITE_ENTRA_SCOPE="api://224ccefb-cfa7-42ba-9440-1f1b03aaca72/deploy"
